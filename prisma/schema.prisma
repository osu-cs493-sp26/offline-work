datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    output = "../generated/prisma"
}

model Lodging {
    id              Int         @id @default(autoincrement())
    createdAt       DateTime    @default(now())
    name            String
    description     String
    street          String
    city            String
    state           String      @db.VarChar(2)
    zip             String      @db.VarChar(5)
    price           Float
    reservations    Reservation[]
}

model Reservation {
    id          Int         @id @default(autoincrement())
    createdAt   DateTime    @default(now())
    start       DateTime
    end         DateTime
    lodging     Lodging     @relation(fields: [lodgingId], references: [id], onDelete: Cascade)
    lodgingId   Int
}

model User {
    id          Int         @id @default(autoincrement())
    createdAt   DateTime    @default(now())
    email       String      @unique
    password    String
}

model Image {
    id          Int         @id @default(autoincrement())
    createdAt   DateTime    @default(now())
    type        String
    filename    String      @unique
    path        String
    caption     String?
    tags        String[]
}
